# Python — Python's standard ignore list is anchored to root (leading /)
# because these names (lib/, var/, build/, dist/, etc.) ALSO appear in
# legitimate frontend paths (e.g., web/src/lib/, web/dist/). Without the
# anchor, `lib/` would silently swallow the entire web/src/lib/ source
# tree — discovered in Phase 11 first-push fallout. Path-specific
# overrides for the frontend appear below.
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
/build/
develop-eggs/
/dist/
downloads/
eggs/
.eggs/
/lib/
/lib64/
parts/
/sdist/
/var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
.venv/
venv/
env/
ENV/

# Tools
.pytest_cache/
.mypy_cache/
.ruff_cache/
.hypothesis/
.coverage
.coverage.*
htmlcov/
.tox/

# Node
node_modules/
web/dist/
web/.vite/
.npm/
*.log
npm-debug.log*
*.tsbuildinfo

# IDE
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# Runtime data (the volume contents — never commit)
/data/
/.restream-plus-db/
/.dev-data/

# Dev-only tooling — start.py downloads MediaMTX on first run.
/dev/mediamtx.exe
/dev/mediamtx.exe.sha256
/dev/*.zip
*.db
*.db-journal
*.db-wal
*.db-shm

# Local env files
.env
.env.local
.env.*.local

# Secrets — defense in depth
*.pem
*.key
*.crt
*.p12
.kdf_salt
.first-boot-password

# Build artifacts
*.tar
*.tar.gz
docker-image-*.tar
