# .github/checksums.env — single source of truth for upstream tarball pins.
#
# Consumed by .github/workflows/build-image.yml and release.yml, then
# passed to the Dockerfile as build-args. The Dockerfile gates each
# download through `sha256sum -c -` when the corresponding ARG is set.
#
# AUTOMATION
# ----------
# Renovate (.github/renovate.json5) maintains the version fields below
# via customManagers; scripts/refresh-checksums.sh recomputes the SHA-256
# fields atomically via the postUpgradeTasks hook. Human edits are an
# emergency-override path only — there is no other automated writer to
# this file.
#
# BOOTSTRAP
# ---------
# Initial values populated 2026-05-17 via:
#   curl -fsSL https://nginx.org/download/nginx-1.26.2.tar.gz | sha256sum
#   curl -fsSL https://github.com/arut/nginx-rtmp-module/archive/<sha>.tar.gz | sha256sum
#   curl -fsSL https://github.com/just-containers/s6-overlay/releases/download/v3.2.0.2/s6-overlay-<arch>.tar.xz.sha256
#
# IMPORTANT
# ---------
# NGINX_RTMP_MODULE_SHA changed from the Phase 10 value
# (9879e1de32b2624e44ec8d99a9e286d59c41bd54 — does NOT exist on GitHub)
# to v1.2.2 release commit (23e1873aa62acb58b7881eed2a501f5bf35b82e9).
# See docs/architecture/phase-11-design-memo.md §R-14.

NGINX_VERSION=1.30.1
NGINX_SHA256=99765000d974896b31ca5882d8c279ce3fe7ef6f5c6f9f0a967ed7fd3407f9cc

NGINX_RTMP_MODULE_SHA=23e1873aa62acb58b7881eed2a501f5bf35b82e9
NGINX_RTMP_MODULE_TARBALL_SHA256=b688919355c0acccdda24eb83c6306df3d450cb0b13664f16b8e3d1f521c3bb5

S6_OVERLAY_VERSION=3.2.0.2
S6_OVERLAY_NOARCH_SHA256=6dbcde158a3e78b9bb141d7bcb5ccb421e563523babbe2c64470e76f4fd02dae
